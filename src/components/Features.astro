---
// Features section - Key features with icons
const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
    title: "Explorar Destinos",
    description: "Fichas completas de museos y atractivos con imágenes, descripción detallada, horarios de visita y ubicación en mapa interactivo."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618V5.382a1 1 0 00-1.447-.894L15 7M15 10l-6-3M15 10v10m-6-7l-4.553 2.276A1 1 0 003 16.382v-3.236a1 1 0 01.553-.894L9 10m0 0V7m0 3v10" /></svg>`,
    title: "Realidad Aumentada",
    description: "Inicia un recorrido AR dentro del museo y obtén información adicional en tiempo real sobre lo que estás viendo, acompañado de audio guía."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>`,
    title: "Modo Offline",
    description: "Accede a guías, mapas y fichas sin conexión a internet. Los datos se almacenan localmente con Room Database para garantizar persistencia entre sesiones."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    title: "Favoritos e Itinerarios",
    description: "Guarda tus lugares favoritos y planifica visitas en tiempo real. Organiza tu recorrido y optimiza cada salida turística con un solo toque."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>`,
    title: "Eventos y Notificaciones",
    description: "Recibe alertas sobre eventos culturales, religiosos y gastronómicos de la ciudad. Servicio en background con notificación persistente para seguimiento activo."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    title: "Galería de Viajes",
    description: "Sube y organiza fotos tomadas durante tus recorridos. Visualiza imágenes en tamaño completo, descárgalas o compártelas directamente desde la app."
  }
];
---

<section id="features" class="relative py-24 lg:py-32">
  <!-- Section Divider -->
  <div class="section-divider mb-24"></div>

  <!-- Background -->
  <div class="glow-orb w-[400px] h-[400px] bg-accent-500 top-0 right-0"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="inline-block text-sm font-semibold text-accent-400 uppercase tracking-widest mb-4">Características</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold mb-6">
        Todo lo que necesitas para
        <span class="gradient-text">explorar sin límites</span>
      </h2>
      <p class="text-lg text-slate-400 leading-relaxed">
        Desde fichas completas de destinos hasta recorridos en Realidad Aumentada — PeruStar reúne todas las herramientas del turista moderno en una sola app.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {features.map((feature, index) => (
        <div
          class="glass-card rounded-2xl p-8 group"
          style={`animation: slideIn 0.6s ease-out ${index * 0.1}s forwards; opacity: 0;`}
        >
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-600/20 to-accent-600/20 flex items-center justify-center text-primary-400 mb-6 group-hover:from-primary-600/30 group-hover:to-accent-600/30 transition-all duration-300">
            <Fragment set:html={feature.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-xl font-heading font-semibold text-white mb-3">{feature.title}</h3>
          <p class="text-slate-400 leading-relaxed text-sm">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
