---
// RevenueStreams section - Modelo de negocio / Flujos de ingresos
const plans = [
  {
    tag: "Gratis",
    name: "Versión Gratuita",
    price: "S/ 0",
    period: "siempre",
    highlight: false,
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
    color: "from-slate-500 to-slate-600",
    features: [
      "Acceso a museos y atractivos principales",
      "Eventos culturales básicos",
      "Favoritos e itinerarios simples",
      "Información offline limitada"
    ]
  },
  {
    tag: "Más popular",
    name: "Versión Premium",
    price: "S/ 9.90",
    period: "al mes",
    highlight: true,
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
    color: "from-primary-500 to-accent-500",
    features: [
      "Audioguías completas y sin anuncios",
      "Realidad Aumentada avanzada",
      "Descargas ilimitadas offline",
      "Idiomas adicionales",
      "Rutas personalizadas"
    ]
  },
  {
    tag: "B2B",
    name: "Publicidad Segmentada",
    price: "Variable",
    period: "por campaña",
    highlight: false,
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" /></svg>`,
    color: "from-orange-400 to-amber-500",
    features: [
      "Promoción de restaurantes",
      "Promoción de hoteles",
      "Promoción de agencias de viaje",
      "Promoción de artesanos locales"
    ]
  }
];
---

<section id="ingresos" class="relative py-24 lg:py-32">
  <div class="section-divider mb-24"></div>

  <!-- Background -->
  <div class="glow-orb w-[500px] h-[500px] bg-primary-500 top-1/4 left-0"></div>
  <div class="glow-orb w-[400px] h-[400px] bg-accent-500 bottom-0 right-0"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <span class="inline-block text-sm font-semibold text-accent-400 uppercase tracking-widest mb-4">Modelo de Negocio</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold mb-6">
        Flujos de
        <span class="gradient-text">Ingresos</span>
      </h2>
      <p class="text-lg text-slate-400 leading-relaxed">
        Un modelo freemium sostenible: planes para el usuario final y alianzas comerciales con actores del turismo local.
      </p>
    </div>

    <!-- Plans Grid -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 items-stretch max-w-6xl mx-auto">
      {plans.map((plan, index) => (
        <div
          class:list={[
            "relative rounded-3xl p-8 flex flex-col transition-all duration-300",
            plan.highlight
              ? "glass-card border-2 border-accent-500/40 md:scale-105 shadow-2xl shadow-accent-600/10"
              : "glass-card"
          ]}
          style={`animation: slideIn 0.6s ease-out ${index * 0.12}s forwards; opacity: 0;`}
        >
          <!-- Badge -->
          <span
            class:list={[
              "inline-block self-start text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-6",
              plan.highlight
                ? "bg-accent-500/15 text-accent-400 border border-accent-500/30"
                : "bg-white/5 text-slate-400 border border-white/10"
            ]}
          >
            {plan.tag}
          </span>

          <!-- Icon -->
          <div class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${plan.color} p-0.5 mb-6`}>
            <div class="w-full h-full rounded-2xl bg-surface-900 flex items-center justify-center text-white">
              <Fragment set:html={plan.icon} />
            </div>
          </div>

          <!-- Name & Price -->
          <h3 class="text-xl font-heading font-semibold text-white mb-1">{plan.name}</h3>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-3xl font-heading font-bold gradient-text">{plan.price}</span>
            <span class="text-sm text-slate-500">{plan.period}</span>
          </div>

          <!-- Features -->
          <ul class="space-y-3 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-slate-400">
                <svg class="w-5 h-5 text-accent-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>