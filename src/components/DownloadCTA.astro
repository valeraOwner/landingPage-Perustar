---
// DownloadCTA section - Call to action for download
---

<section id="descargar" class="relative py-24 lg:py-32">
  <div class="section-divider mb-24"></div>

  <!-- Background Orbs -->
  <div class="glow-orb w-[600px] h-[600px] bg-primary-600 top-0 left-1/2 -translate-x-1/2 opacity-20"></div>
  <div class="glow-orb w-[400px] h-[400px] bg-accent-500 bottom-0 right-1/4 opacity-10"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- CTA Card -->
    <div class="relative glass-card rounded-3xl p-10 sm:p-14 lg:p-20 text-center overflow-hidden animate-pulse-glow">
      <!-- Inner glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 via-transparent to-accent-600/5"></div>

      <!-- Decorative circles -->
      <div class="absolute -top-24 -right-24 w-48 h-48 rounded-full bg-primary-500/10 blur-2xl"></div>
      <div class="absolute -bottom-24 -left-24 w-48 h-48 rounded-full bg-accent-500/10 blur-2xl"></div>

      <div class="relative">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent-500/10 border border-accent-500/20 text-sm text-accent-400 font-medium mb-8">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Disponible ahora — 100% Gratis
        </div>

        <!-- Heading -->
        <h2 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-heading font-bold mb-6 leading-tight">
          ¿Listo para explorar con
          <span class="gradient-text">PeruStar</span>?
        </h2>

        <!-- Description -->
        <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          Descarga la app desde GitHub, instálala en tu Android y empieza a explorar museos, eventos y atractivos culturales con mapas, modo offline y Realidad Aumentada.
        </p>

        <!-- Download Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
          <!-- Primary Download - GitHub -->
          <a
            href="https://github.com/vhanccos/IDNP_PROYECTO_FINAL.git"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary px-10 py-5 rounded-2xl text-white font-semibold text-lg inline-flex items-center justify-center gap-3 group"
          >
            <svg class="w-6 h-6 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Descargar desde GitHub
          </a>

          <!-- Secondary - Source Code -->
          <a
            href="https://github.com/vhanccos/IDNP_PROYECTO_FINAL.git"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary px-10 py-5 rounded-2xl text-slate-300 font-semibold text-lg inline-flex items-center justify-center gap-3"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
            Ver Código Fuente
          </a>
        </div>

        <!-- Platform icons -->
        <div class="flex items-center justify-center gap-6 text-slate-500">
          <span class="text-sm">Disponible en:</span>
          <div class="flex gap-4">
            <!-- Windows -->
            <svg class="w-5 h-5 hover:text-slate-300 transition-colors cursor-pointer" fill="currentColor" viewBox="0 0 24 24">
              <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
            </svg>
            <!-- Apple -->
            <svg class="w-5 h-5 hover:text-slate-300 transition-colors cursor-pointer" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <!-- Linux -->
            <svg class="w-5 h-5 hover:text-slate-300 transition-colors cursor-pointer" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.564.942.244 2.03.184 2.857-.016.454-.11.836-.274 1.132-.508a.64.64 0 00.168-.165c.012-.027.023-.038.033-.06.166-.174.091-.657-.24-.96-.331-.299-.705-.373-1.143-.378-.07 0-.17.007-.164-.045.006-.066.076-.066.164-.078.156-.019.386-.022.573-.062.09-.018.168-.042.235-.083a.46.46 0 00.2-.249c.066-.198.021-.463-.132-.627a1.016 1.016 0 00-.425-.278c.024-.038.038-.082.064-.118.069-.09.164-.164.228-.296.128-.27.024-.578-.192-.795a1.376 1.376 0 00-.555-.315c.075-.138.08-.298.013-.449-.068-.154-.21-.293-.378-.388-.34-.192-.698-.206-1.126-.103-.248.054-.476.172-.792.106-.348-.092-.618-.376-.93-.455-.17-.043-.32-.027-.47.05-.146.076-.292.234-.453.194-.203-.048-.337-.174-.536-.238a1.107 1.107 0 00-.645-.004c-.167.046-.272.112-.475.175-.378.126-.64.273-.91.495-.063.053-.123.11-.186.157-.097.063-.19.14-.277.183-.286.14-.582-.063-.863-.234-.278-.175-.517-.428-.618-.737a1.87 1.87 0 01-.055-.726c.05-.562.267-.977.446-1.41.202-.472.379-.973.479-1.536.1-.566.134-1.187.038-1.9-.16-1.06-.677-2.254-1.41-3.222-1.1-1.333-2.544-2.164-3.79-2.57-.67-.24-1.22-.362-1.651-.417a3.966 3.966 0 00-.545-.044z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
