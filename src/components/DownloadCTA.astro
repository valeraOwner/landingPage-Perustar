---
// DownloadCTA section - Call to action for download
---

<section id="descargar" class="relative py-24 lg:py-32">
  <div class="section-divider mb-24"></div>

  <!-- Background Orbs -->
  <div
    class="glow-orb w-[600px] h-[600px] bg-primary-600 top-0 left-1/2 -translate-x-1/2 opacity-20"
  >
  </div>
  <div
    class="glow-orb w-[400px] h-[400px] bg-accent-500 bottom-0 right-1/4 opacity-10"
  >
  </div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- CTA Card -->
    <div
      class="relative glass-card rounded-3xl p-10 sm:p-14 lg:p-20 text-center overflow-hidden animate-pulse-glow"
    >
      <!-- Inner glow -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-primary-600/5 via-transparent to-accent-600/5"
      >
      </div>

      <!-- Decorative circles -->
      <div
        class="absolute -top-24 -right-24 w-48 h-48 rounded-full bg-primary-500/10 blur-2xl"
      >
      </div>
      <div
        class="absolute -bottom-24 -left-24 w-48 h-48 rounded-full bg-accent-500/10 blur-2xl"
      >
      </div>

      <div class="relative">
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent-500/10 border border-accent-500/20 text-sm text-accent-400 font-medium mb-8"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Disponible ahora — 100% Gratis
        </div>

        <!-- Heading -->
        <h2
          class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-heading font-bold mb-6 leading-tight"
        >
          ¿Listo para explorar con
          <span class="gradient-text">PeruStar</span>?
        </h2>

        <!-- Description -->
        <p
          class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed"
        >
          Descarga la app desde GitHub, instálala en tu Android y empieza a
          explorar museos, eventos y atractivos culturales con mapas, modo
          offline y Realidad Aumentada.
        </p>

        <!-- Download Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
          <!-- Primary Download - GitHub -->
          <a
            href="https://github.com/vhanccos/GES/releases/tag/v0.1.0"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary px-10 py-5 rounded-2xl text-white font-semibold text-lg inline-flex items-center justify-center gap-3 group"
          >
            <svg
              class="w-6 h-6 transition-transform duration-300 group-hover:scale-110"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            Descargar desde GitHub
          </a>

          <!-- Secondary - Source Code -->
          <a
            href="https://github.com/vhanccos/GES/releases/tag/v0.1.0"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary px-10 py-5 rounded-2xl text-slate-300 font-semibold text-lg inline-flex items-center justify-center gap-3"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
            Ver Código Fuente
          </a>
        </div>

        <!-- Platform icons -->
      </div>
    </div>
  </div>
</section>
